# ─── DATABASE ────────────────────────────────────────────────────────────────
# Choose one: mysql or postgresql
DB_TYPE=mysql

# MySQL example
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hr_database
DB_USER=hr_user
DB_PASSWORD=HRproject123!

# PostgreSQL example (uncomment and fill if using PG)
# DB_TYPE=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=hr_database
# DB_USER=hr_user
# DB_PASSWORD=your_password_here

# ─── EXPORT PATHS ────────────────────────────────────────────────────────────
# Folder where Tableau reads refreshed CSV files from
EXPORT_DIR=./exports

# ─── SALARY BENCHMARK API ────────────────────────────────────────────────────
# We use BLS public API (free, no key required for basic access)
# Optional: register at https://www.bls.gov/developers/ for higher rate limits
BLS_API_KEY=

# ─── MODEL ───────────────────────────────────────────────────────────────────
MODEL_DIR=./models
RETRAIN_ON_STARTUP=false

# ─── SCHEDULER ───────────────────────────────────────────────────────────────
# How often to refresh exports (in hours)
REFRESH_INTERVAL_HOURS=6
